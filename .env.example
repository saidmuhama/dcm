# DCM Application Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to version control.

# 256-bit hex key for URL parameter encryption (AES-256-CBC + HMAC-SHA256).
# Generate a new key: php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
URL_CRYPT_KEY=your_64_hex_character_key_here
